<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- 日志目录可被 application.yml 的 logging.file.path(${LOG_DIR:./logs}) 覆盖 -->
  <property name="LOG_DIR" value="${LOG_DIR:-./logs}"/>
  <property name="LOG_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>

  <!-- 滚动文件:按天轮转,单文件 100MB 上限,保留 30 天;只收 INFO 以上 -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/orientation.log</file>
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>INFO</level>
    </filter>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/orientation.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>100MB</maxFileSize>
      <maxHistory>30</maxHistory>
      <totalSizeCap>3GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="FILE"/>
    <appender-ref ref="CONSOLE"/>
  </root>

  <!-- 本地开发:控制台更详细(DEBUG 应用包 + SQL 参数),文件仍只收 INFO -->
  <springProfile name="local">
    <logger name="com.gmnl.orientation" level="DEBUG"/>
    <logger name="org.hibernate.orm.deprecation" level="INFO"/>
  </springProfile>
</configuration>
