# 本地开发配置示例:复制为 application-local.yml(已被 .gitignore 忽略)后按需修改。
# 主配置 application.yml 不再强制 profiles.active=local,启动时需显式指定:
#   mvn spring-boot:run -Dspring-boot.run.profiles=local
# 或设置环境变量 SPRING_PROFILES_ACTIVE=local。
spring:
  datasource:
    url: jdbc:postgresql://localhost:5433/orientation
    username: orientation_app
    password: orientation_dev_pass

# JWT 密钥:主配置无默认值,本地必须在此提供(≥32 字节)。
app:
  jwt:
    secret: dev-secret-change-me-please-make-it-long-enough-32bytes

# Swagger/OpenAPI 默认关闭,本地开发开启以便调试;其他环境用 SWAGGER_ENABLED=true。
springdoc:
  api-docs:
    enabled: true
  swagger-ui:
    enabled: true
